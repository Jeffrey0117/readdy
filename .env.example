# Required: random salt for hashing client IPs (anti-abuse, no plaintext IPs stored)
READDY_IP_SALT=change_me_to_a_long_random_string

# Optional: public URL used to build the share link returned by POST /api/paste
# Defaults to http://localhost:4022 if unset
READDY_PUBLIC_URL=https://readdy.isnowfriend.com

# Optional: port override (default 4022)
PORT=4022
